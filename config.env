#!/bin/bash
################################################################################
# NuoPanel - Configuracao Centralizada
################################################################################

# GitHub Base
REPO_BASE="https://raw.githubusercontent.com/SolusTec/NuoPanel/main"

# Assets
PANEL_ZIP_URL="${REPO_BASE}/assets/panel_latest.zip"
BASE_APPS_URL="${REPO_BASE}/assets/base_apps_config.zip"
SOFTACULOUS_ZIP_URL="${REPO_BASE}/assets/softaculous.zip"
INSTALL_ZIP_URL="${REPO_BASE}/assets/install.zip"

# Config Files
REQUIREMENTS_UBUNTU_URL="${REPO_BASE}/config/ubuntu.txt"
REQUIREMENTS_CENTOS_URL="${REPO_BASE}/config/centos.txt"
BANNER_SCRIPT_URL="${REPO_BASE}/config/banner-ssh.sh"
HTTPD_CONFIG_URL="${REPO_BASE}/config/httpd_config.conf"
VHCONF_EXAMPLE_URL="${REPO_BASE}/config/vhosts/Example/vhconf.conf"
VHCONF_MYPANEL_URL="${REPO_BASE}/config/vhosts/mypanel/vhconf.conf"
CP_SERVICE_URL="${REPO_BASE}/config/cp.service"

# External Scripts (kept from original for compatibility)
OLSPANEL_RE_CONFIG="https://olspanel.com/extra/re_config.sh"
OLSPANEL_SSL_SETUP="https://olspanel.com/extra/setup_missing_ssl_file.sh"
OLSPANEL_SWAP="https://olspanel.com/extra/swap.sh"
OLSPANEL_DB_UPDATE="https://olspanel.com/extra/database_update.sh"

# PHP Versions
PHP_VERSIONS="74 80 81 82 83 84 85"
PHP_DEFAULT_VERSION="81"

# Directories
WORK_DIR="/root/nuopanel-install"
ITEM_DIR="/root/item"
PANEL_DIR="/usr/local/lsws/Example/html/mypanel"
VENV_PATH="/root/venv"
OLS_CONF_DIR="/usr/local/lsws/conf"
LOG_DIR="/var/log/nuopanel"
INSTALL_LOG="/var/log/nuopanel/install.log"

# Database
DB_NAME="panel"
DB_USER="panel"
DB_ROOT_PASSWORD_FILE="/root/item/mysqlPassword"
DB_USER_PASSWORD_FILE="/root/db_credentials_panel.txt"

# System Detection - ROBUST
detect_os() {
    # Detectar OS base
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        OS_NAME=$ID
        OS_VERSION=${VERSION_ID%%.*}
    elif [ -f /etc/centos-release ]; then
        OS_NAME="centos"
        OS_VERSION=$(awk '{print $4}' /etc/centos-release | cut -d. -f1)
    elif [ -f /etc/debian_version ]; then
        OS_NAME="debian"
        OS_VERSION=$(cat /etc/debian_version | cut -d. -f1)
    else
        echo "Sistema operacional nao suportado"
        exit 1
    fi
    
    # Para Ubuntu, obter versão específica
    if [ "$OS_NAME" = "ubuntu" ]; then
        if command -v lsb_release &> /dev/null; then
            UBUNTU_VERSION=$(lsb_release -sr | cut -d. -f1)
        else
            UBUNTU_VERSION=$OS_VERSION
        fi
        
        # Definir serviço OpenLiteSpeed baseado na versão
        if [ "$UBUNTU_VERSION" -ge 24 ]; then
            SYSTEMD_SERVICE="lshttpd"
        else
            SYSTEMD_SERVICE="lsws"
        fi
    elif [ "$OS_NAME" = "debian" ]; then
        SYSTEMD_SERVICE="lsws"
    elif [ "$OS_NAME" = "centos" ]; then
        SYSTEMD_SERVICE="lsws"
    else
        SYSTEMD_SERVICE="lsws"
    fi
    
    echo "Sistema detectado: $OS_NAME $OS_VERSION"
}

# Executar detecção
detect_os

# Exportar variáveis
export OS_NAME
export OS_VERSION
export UBUNTU_VERSION
export SYSTEMD_SERVICE

# Firewall Ports
FIREWALL_PORTS="22 25 53 80 110 143 443 465 587 993 995 7080 3306 5353 6379 21 223 155 220 2205"
FTP_PASSIVE_RANGE="40110:40210"

# Version
NUOPANEL_VERSION="2.0.0"
